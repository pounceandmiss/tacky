+/*
+ *--------------------------------------------------------------
+ *
+ * BubbleAdjacent --
+ *
+ *	Determine whether a neighboring display line continues the same bubble,
+ *	i.e. whether it carries a chunk with the same -bubblecolor. Keyed on the
+ *	bubble colour (not the style pointer) so that a selection inside the
+ *	bubble -- which changes the character style but not the bubble colour --
+ *	does not look like a bubble boundary. Used to decide which corners of a
+ *	bubble's per-line rectangle to round: a corner is rounded only on the
+ *	edge where the bubble is not continued by the line above/below.
+ *
+ * Results:
+ *	1 if neighborPtr is non-NULL and carries the same bubbleBorder, else 0.
+ *
+ *--------------------------------------------------------------
+ */
+
+static int
+BubbleAdjacent(
+    DLine *neighborPtr,		/* Display line above or below, or NULL. */
+    Tk_3DBorder bubbleBorder)	/* Bubble colour being drawn. */
+{
+    TkTextDispChunk *chunkPtr;
+
+    if (neighborPtr == NULL) {
+	return 0;
+    }
+    for (chunkPtr = neighborPtr->chunkPtr; chunkPtr != NULL;
+	    chunkPtr = chunkPtr->nextPtr) {
+	if (chunkPtr->stylePtr->sValuePtr->bubbleBorder == bubbleBorder) {
+	    return 1;
+	}
+    }
+    return 0;
+}
+
+/*
+ *--------------------------------------------------------------
+ *
+ * BubbleLineExtent --
+ *
+ *	Find the horizontal extent of the chunks on a single display line that
+ *	carry bubble colour bb: the left edge of the first such chunk and the
+ *	right edge of the last. Keyed on bubbleBorder so a selection inside the
+ *	bubble (which changes the character style but not the bubble colour)
+ *	does not affect the result.
+ *
+ * Results:
+ *	1 if the line carries bb (with leftPtr, rightPtr filled), else 0.
+ *
+ *--------------------------------------------------------------
+ */
+
+static int
+BubbleLineExtent(
+    DLine *dlPtr,
+    Tk_3DBorder bb,
+    int *leftPtr,
+    int *rightPtr)
+{
+    TkTextDispChunk *chunkPtr;
+    int found = 0, left = 0, right = 0;
+
+    for (chunkPtr = dlPtr->chunkPtr; chunkPtr != NULL;
+	    chunkPtr = chunkPtr->nextPtr) {
+	if (chunkPtr->stylePtr->sValuePtr->bubbleBorder == bb) {
+	    if (!found) {
+		left = chunkPtr->x;
+		found = 1;
+	    }
+	    right = chunkPtr->x + chunkPtr->width;
+	}
+    }
+    if (found) {
+	*leftPtr = left;
+	*rightPtr = right;
+    }
+    return found;
+}
+
+/*
+ *--------------------------------------------------------------
+ *
+ * BubbleRunBounds --
+ *
+ *	Compute the bounding-box left/right extent of the whole bubble that
+ *	dlPtr belongs to. A bubble spans a maximal run of vertically-contiguous
+ *	display lines that all carry bubble colour bb; this returns the minimum
+ *	left and maximum right over every line in that run, so that each line is
+ *	drawn out to the widest line's edge (a clean rectangle) instead of
+ *	hugging its own ragged text width. The display-line list (sorted top to
+ *	bottom) is scanned to locate the run containing dlPtr.
+ *
+ *--------------------------------------------------------------
+ */
+
+static void
+BubbleRunBounds(
+    TkText *textPtr,
+    DLine *dlPtr,
+    Tk_3DBorder bb,
+    int *leftPtr,
+    int *rightPtr)
+{
+    DLine *p;
+    int l, r;
+
+    /*
+     * Fall back to this line alone; overwritten below once the run containing
+     * dlPtr is found.
+     */
+
+    if (!BubbleLineExtent(dlPtr, bb, leftPtr, rightPtr)) {
+	return;
+    }
+    for (p = textPtr->dInfoPtr->dLinePtr; p != NULL; ) {
+	if (BubbleLineExtent(p, bb, &l, &r)) {
+	    int runLeft = l, runRight = r, contains = (p == dlPtr);
+	    DLine *n = p->nextPtr;
+
+	    while ((n != NULL) && BubbleLineExtent(n, bb, &l, &r)) {
+		if (l < runLeft) {
+		    runLeft = l;
+		}
+		if (r > runRight) {
+		    runRight = r;
+		}
+		if (n == dlPtr) {
+		    contains = 1;
+		}
+		n = n->nextPtr;
+	    }
+	    if (contains) {
+		*leftPtr = runLeft;
+		*rightPtr = runRight;
+		return;
+	    }
+	    p = n;
+	} else {
+	    p = p->nextPtr;
+	}
+    }
+}
