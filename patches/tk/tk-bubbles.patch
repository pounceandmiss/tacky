+/*
+ *--------------------------------------------------------------
+ *
+ * FillRoundedBubble --
+ *
+ *	Fill a rectangle whose corners may individually be rounded with a
+ *	quarter disc of the given radius. Drawing uses plain server-side
+ *	primitives (no anti-aliasing); that is intentional for the bubble MVP.
+ *	A square corner is requested by passing 0 for that corner.
+ *
+ * Results:
+ *	None.
+ *
+ * Side effects:
+ *	Paints onto drawable with gc.
+ *
+ *--------------------------------------------------------------
+ */
+
+static void
+FillRoundedBubble(
+    Display *display,
+    Drawable drawable,
+    GC gc,
+    int x, int y,		/* Top-left of the rectangle. */
+    int width, int height,
+    int radius,			/* Corner radius (already clamped by caller). */
+    int tl, int tr, int bl, int br)
+				/* Non-zero => round that corner. */
+{
+    int d = 2 * radius;
+
+    /*
+     * Overlap the bands 1px into the arc boxes on rounded sides to hide the
+     * seam where a rectangle fill meets an arc (a white hairline under GDI,
+     * which rasterizes the two edges differently). Rounded sides only, so
+     * square stacked lines still abut.
+     */
+
+    int topOv = (tl || tr) ? 1 : 0;
+    int botOv = (bl || br) ? 1 : 0;
+
+    /*
+     * GDI draws XFillArc (via Pie) one pixel wider on the right and bottom than
+     * the rectangle fills (DrawOrFillArc's +1 box; fill right/bottom edges are
+     * exclusive). Pad the right edge and rounded bottom to match. No-op on X11.
+     */
+
+#ifdef _WIN32
+    int rBulge = 1;
+    int bBulge = botOv;
+#else
+    int rBulge = 0;
+    int bBulge = 0;
+#endif
+
+    if (radius <= 0 || width <= 0 || height <= 0) {
+	XFillRectangle(display, drawable, gc, x, y,
+		(unsigned) width, (unsigned) height);
+	return;
+    }
+
+    /*
+     * Body: a full-width middle band, plus top and bottom bands that stop
+     * short of any rounded corner (square corners run flush to the edge so
+     * stacked lines of the same bubble meet seamlessly).
+     */
+
+    XFillRectangle(display, drawable, gc, x, y + radius - topOv,
+	    (unsigned) (width + rBulge), (unsigned) (height - d + topOv + botOv));
+    XFillRectangle(display, drawable, gc,
+	    x + (tl ? radius - 1 : 0), y,
+	    (unsigned) (width - (tl ? radius - 1 : 0) - (tr ? radius - 1 : 0) + rBulge),
+	    (unsigned) radius);
+    XFillRectangle(display, drawable, gc,
+	    x + (bl ? radius - 1 : 0), y + height - radius,
+	    (unsigned) (width - (bl ? radius - 1 : 0) - (br ? radius - 1 : 0) + rBulge),
+	    (unsigned) (radius + bBulge));
+
+    /*
+     * Rounded corners: a filled quarter disc per requested corner. X arc
+     * angles are in 64ths of a degree, counter-clockwise from 3 o'clock.
+     */
+
+    if (tl) {
+	XFillArc(display, drawable, gc, x, y,
+		(unsigned) d, (unsigned) d, 90 * 64, 90 * 64);
+    }
+    if (tr) {
+	XFillArc(display, drawable, gc, x + width - d, y,
+		(unsigned) d, (unsigned) d, 0, 90 * 64);
+    }
+    if (bl) {
+	XFillArc(display, drawable, gc, x, y + height - d,
+		(unsigned) d, (unsigned) d, 180 * 64, 90 * 64);
+    }
+    if (br) {
+	XFillArc(display, drawable, gc, x + width - d, y + height - d,
+		(unsigned) d, (unsigned) d, 270 * 64, 90 * 64);
+    }
+}
 
